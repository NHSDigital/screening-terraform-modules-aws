# WARNING: Please, DO NOT edit this section of the file! It is maintained in the repository template.

.scannerwork
*cloc*report*.json
*sbom*report*.json
*vulnerabilities*report*.json
*report*json.zip
.version

*.code-workspace
!project.code-workspace

# Please, add your custom content below!

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files, which are likely to contain sentitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Terraform lock files
#**/.terraform.lock.hcl

# Ignore aliased provider files, which are required for Terraform to function but do not need to be checked in
**/aliased-providers.tf.json

# Lambda build artifacts
builds/
__pycache__/
*.zip
.tox

# Local editors/macos files
.DS_Store
.idea

# Dependency directories
node_modules/
